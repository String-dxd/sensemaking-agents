{
  "$schema": "https://biomejs.dev/schemas/2.3.0/schema.json",
  "files": {
    "includes": [
      "src/**/*.{ts,tsx,js,jsx,json}",
      "test/**/*.{ts,tsx,json}",
      "scripts/**/*.{ts,tsx}",
      "trigger/**/*.{ts,tsx}",
      "!**/routeTree.gen.ts",
      "!**/.output/**",
      "!**/dist/**",
      "!**/node_modules/**"
    ]
  },
  "css": {
    "parser": { "cssModules": false }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noNonNullAssertion": "warn",
        "useImportType": "warn"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded",
      "trailingCommas": "all"
    }
  }
}
