# =============================================================================
# Sensemaking Agents v0.1 — environment variables
# =============================================================================
# Copy this file to `.env` (gitignored), then fill in the values below.
#   cp .env.example .env
#
# Each key is grouped by which feature it unlocks. The app degrades cleanly
# without optional keys — you can run `pnpm test` and `pnpm dev` for the
# wiki UI without any of them. The voice path needs OPENAI_API_KEY; the
# cron path needs the TRIGGER_* pair.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED for voice (Mirror live session) and any sense-making LLM calls.
# Used by: server/mirror-session.handler.server.ts (mints OpenAI Realtime
# ephemeral tokens), agents/connector.ts, agents/pathfinder.ts,
# agents/tools/self-critique.ts.
#
# Where to get it:
#   1. Sign in at https://platform.openai.com/
#   2. Create a project key under Settings → API keys → Create new secret key.
#   3. Make sure the key has access to the Realtime API (gpt-realtime-2)
#      and gpt-4.1.
#
# Format: starts with `sk-` followed by ~50 alphanumerics.
# Server-side only — never imported into browser code; the browser receives
# a short-lived ephemeral session token instead.
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-replace-me


# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED for the cron path (Connector → Pathfinder Handoff chain).
# Used by: trigger/sense-make.ts, server/schedule-onboard.handler.server.ts,
# server/trigger-cron.handler.server.ts.
#
# Where to get them:
#   1. Sign in at https://cloud.trigger.dev/
#   2. Create a project (any name; e.g. `sensemaking-agents`).
#   3. Project → API Keys: copy the DEV secret key (starts with `tr_dev_`).
#      For prod deploys, use the prod key (starts with `tr_prod_`).
#   4. Project → Settings: copy the Project Ref (starts with `proj_`).
#
# Without these, the wiki "Run sense-making now" button will fail with a
# clear error, but Mirror live (voice) and the wiki UI keep working.
# ─────────────────────────────────────────────────────────────────────────────
TRIGGER_SECRET_KEY=tr_dev_replace-me
TRIGGER_PROJECT_REF=proj_replace-me


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — overrides for local dev. Defaults work for the demo.
# ─────────────────────────────────────────────────────────────────────────────

# SQLite path. Created automatically on first run; chmod 0600 by the app.
# Use `:memory:` for fully ephemeral runs (tests already do this).
DATABASE_PATH=./app.db

# v0.1 has no auth — every request writes against this student id.
# Override only if you want to compare ablation runs across separate corpora.
DEFAULT_STUDENT_ID=demo

# Node env. Affects the dev-only "Run sense-making now" button on /wiki
# (hidden when NODE_ENV=production) and Trigger.dev's dev vs prod schedule
# routing. Leave unset locally — vite/tsx default this to "development".
# NODE_ENV=development
