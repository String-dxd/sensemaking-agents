{
  "name": "sensemaking-agents",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node .output/server/index.mjs",
    "check": "biome check src test && tsc --noEmit",
    "lint": "biome check src test",
    "format": "biome format --write src test",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx src/db/seed.ts",
    "db:generate": "drizzle-kit generate --config=src/db/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/db/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=src/db/drizzle.config.ts",
    "ablate:mirror": "tsx scripts/ablate.ts --surface=mirror",
    "ablate:sensemake": "tsx scripts/ablate.ts --surface=sensemake",
    "ablate:delta": "tsx scripts/ablate-delta.ts",
    "provision:managed-agents": "tsx scripts/managed-agents/provision.ts",
    "smoke:managed-mirror": "tsx scripts/managed-agents/smoke-mirror.ts",
    "smoke:managed-connector": "tsx scripts/managed-agents/smoke-connector.ts",
    "smoke:managed-cartographer": "tsx scripts/managed-agents/smoke-cartographer.ts",
    "rubric:managed-cartographer": "tsx scripts/managed-agents/cartographer-rubric-batch.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-start": "1.167.65",
    "@vercel/functions": "^2.0.0",
    "@workos/authkit-tanstack-react-start": "^0.8.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.36.0",
    "lucide-react": "^0.468.0",
    "openai": "^6.0.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "zod": "^4.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "@tanstack/history": "1.161.6",
      "@tanstack/react-router": "1.169.2",
      "@tanstack/react-start": "1.167.65",
      "@tanstack/react-start-client": "1.166.48",
      "@tanstack/react-start-rsc": "0.0.44",
      "@tanstack/react-start-server": "1.166.52",
      "@tanstack/router-core": "1.169.2",
      "@tanstack/router-generator": "1.166.42",
      "@tanstack/router-plugin": "1.167.35",
      "@tanstack/router-utils": "1.161.8",
      "@tanstack/start-client-core": "1.168.2",
      "@tanstack/start-fn-stubs": "1.161.6",
      "@tanstack/start-plugin-core": "1.169.20",
      "@tanstack/start-server-core": "1.167.30",
      "@tanstack/start-storage-context": "1.166.35",
      "@tanstack/virtual-file-routes": "1.161.7"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "better-sqlite3": "^12.0.0",
    "drizzle-kit": "^0.30.0",
    "happy-dom": "^15.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^5.1.0",
    "vitest": "^3.0.0"
  }
}
