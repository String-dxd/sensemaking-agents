{
  "name": "character-studio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Character Studio \u2014 internal tool for authoring animated 3D animal companions (drawn-face toon aesthetic, spring-bone secondary motion). Isolated pnpm root; see plans/000-architecture-and-strategy.md.",
  "scripts": {
    "dev": "vite --port 5190",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "export:character": "tsx scripts/export-character.ts",
    "make:fixture": "tsx scripts/make-fixture.ts",
    "gen:skeleton-json": "tsx scripts/export-skeleton-json.ts",
    "gen:face-atlas": "tsx scripts/generate-face-atlas.ts",
    "gen:assets": "pnpm gen:skeleton-json && /Applications/Blender.app/Contents/MacOS/Blender -b --python scripts/blender/gen_assets.py",
    "gen:clips": "pnpm gen:skeleton-json && /Applications/Blender.app/Contents/MacOS/Blender -b --python scripts/blender/clips.py",
    "gen:wardrobe": "pnpm gen:skeleton-json && /Applications/Blender.app/Contents/MacOS/Blender -b --python scripts/blender/wardrobe.py"
  },
  "dependencies": {
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@react-three/postprocessing": "^3.0.0",
    "n8ao": "^1.9.0",
    "postprocessing": "^6.36.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.4.1",
    "@gltf-transform/extensions": "^4.4.1",
    "@gltf-transform/functions": "^4.4.1",
    "@sensemaking/companion-runtime": "workspace:*",
    "meshoptimizer": "^1.1.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.22.5",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
